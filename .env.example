# Backend auth
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=600
ENABLE_BROKEN_AUTH_CHALLENGE=true

# Backend DB URLs
DATABASE_URL=mysql+pymysql://user:password@main_db/scale_db
SQLI_DATABASE_URL=mysql+pymysql://user:password@challenge_db_sqli/testdb
CSRF_DATABASE_URL=mysql+pymysql://user:password@challenge_db_csrf/csrfdb

# Sandbox controls
SANDBOX_MAX_CODE_CHARS=200000

# Frontend
VITE_API_URL=http://localhost:8000

# Main DB container credentials
MYSQL_DATABASE=scale_db
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=rootpassword

# SQLi DB container credentials
SQLI_MYSQL_DATABASE=testdb
SQLI_MYSQL_USER=user
SQLI_MYSQL_PASSWORD=password
SQLI_MYSQL_ROOT_PASSWORD=rootpassword

# CSRF DB container credentials
CSRF_MYSQL_DATABASE=csrfdb
CSRF_MYSQL_USER=user
CSRF_MYSQL_PASSWORD=password
CSRF_MYSQL_ROOT_PASSWORD=rootpassword

