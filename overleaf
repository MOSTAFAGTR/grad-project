skinparam sequence {
  LifeLineBorderColor #1e3a8a
  LifeLineBackgroundColor #eff6ff
  ParticipantBorderColor #0f172a
  ParticipantBackgroundColor #e2e8f0
  ActorBorderColor #7c2d12
  ActorBackgroundColor #ffedd5
}

actor Admin
participant Frontend
participant "Backend /api/auth" as Auth
database "main_db.users" as DB

Admin -> Frontend: Click Approve Instructor
Frontend -> Auth: POST /admin/approve/{id}\nBearer admin JWT
Auth -> Auth: Validate JWT + role==admin
Auth -> DB: UPDATE users SET is_approved=true
DB --> Auth: success
Auth --> Frontend: {message: approved}
Frontend --> Admin: UI refresh (pending list updated)
@enduml
