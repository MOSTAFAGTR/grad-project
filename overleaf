    \caption{Sandbox Execution Process Flow}
    \label{fig:sandbox_flow}
\end{figure}

\textbf{Sandbox Fix-Validation Algorithm (implemented behaviour)}
\begin{itemize}
    \item Receive \texttt{challenge\_dir} and submitted code string.
    \item Validate \texttt{challenge\_dir} against \texttt{ALLOWED\_CHALLENGE\_DIRS} and enforce \texttt{SANDBOX\_MAX\_CODE\_CHARS}.
    \item Copy challenge directory to temporary workspace.
    \item Overwrite \texttt{app.py} with submitted code.
    \item Generate temporary Dockerfile (Python 3.9 slim, dependency install, CRLF normalization for \texttt{run\_tests.sh}).
    \item Build image and run container with \texttt{mem\_limit=256m}, \texttt{cpu\_quota=50000}, \texttt{pids\_limit=128} on \texttt{scale\_net}.
    \item Wait with timeout \texttt{SANDBOX\_RUN\_TIMEOUT}; kill if exceeded.
    \item Parse unittest summary from logs: \texttt{tests\_run}, \texttt{failures}, \texttt{errors}.
    \item Compute success if exit code is 0 and both failure/error counts are zero.
    \item Remove container and temporary image.
    \item Return structured JSON for frontend modal and progress updates.
\end{itemize}

\subsection{Interaction viewpoint}

\textbf{Example interaction: Admin approves instructor account (FR20)}
\begin{itemize}
    \item Admin opens pending requests list.
    \item Frontend sends \texttt{POST /api/auth/admin/approve/\{user\_id\}} with admin JWT.
    \item Backend validates token and role using \texttt{get\_current\_admin}.
    \item CRUD layer updates \texttt{users.is\_approved = True}.
    \item Backend returns success response.
    \item Instructor can now authenticate successfully; prior attempts return HTTP 403.
\end{itemize}

